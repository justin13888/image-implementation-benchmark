def get_system_info() -> Dict[str, Any]:
    """Collect system information for reproducibility manifest."""
    info = {
        "timestamp": datetime.datetime.now().isoformat() + "Z",
        "os": f"{platform.system()} {platform.release()}",
        "kernel": platform.version(),
        "cpu": "unknown",
        "cores": os.cpu_count() or 0,
    }

    # Try to get CPU info
    try:
        if platform.system() == "Darwin":
            cpu = (
                subprocess.check_output(["sysctl", "-n", "machdep.cpu.brand_string"])
                .decode()
                .strip()
            )
            info["cpu"] = cpu
        elif platform.system() == "Linux":
            with open("/proc/cpuinfo") as f:
                for line in f:
                    if "model name" in line:
                        info["cpu"] = line.split(":")[1].strip()
                        break
    except Exception:
        pass

    return info


def get_compiler_versions() -> Dict[str, str]:
    """Get versions of all compilers used."""
    versions = {}

    try:
        versions["rustc"] = (
            subprocess.check_output(["rustc", "--version"]).decode().strip()
        )
    except Exception:
        versions["rustc"] = "not found"

    try:
        clang_out = subprocess.check_output(
            ["clang", "--version"], stderr=subprocess.STDOUT
        ).decode()
        versions["clang"] = clang_out.split("\n")[0].strip()
    except Exception:
        versions["clang"] = "not found"

    try:
        versions["cmake"] = (
            subprocess.check_output(["cmake", "--version"])
            .decode()
            .split("\n")[0]
            .strip()
        )
    except Exception:
        versions["cmake"] = "not found"

    return versions


def get_library_versions() -> Dict[str, str]:
    """Attempt to determine versions of image libraries."""
    libraries = {}

    libs_to_check = [
        "libjpeg-turbo",
        "libpng",
        "libwebp",
        "libavif",
        "dav1d",
        "libjxl",
    ]

    for lib in libs_to_check:
        try:
            result = (
                subprocess.check_output(
                    ["pkg-config", "--modversion", lib], stderr=subprocess.DEVNULL
                )
                .decode()
                .strip()
            )
            libraries[lib] = result
        except Exception:
            libraries[lib] = "unknown"

    libraries["mozjpeg"] = "unknown"
    libraries["mimalloc"] = "2.1.2"  # Would need to be detected dynamically
    libraries["hyperfine"] = "unknown"

    try:
        hf_version = (
            subprocess.check_output(["hyperfine", "--version"]).decode().strip()
        )
        libraries["hyperfine"] = (
            hf_version.split()[1] if len(hf_version.split()) > 1 else hf_version
        )
    except Exception:
        pass

    return libraries


def build_projects(formats: List[str], skip_build: bool):
    """Build Rust and C++ projects."""
    if skip_build:
        print("Skipping build step (--skip-build)")
        return

    print("=" * 70)
    print("BUILDING PROJECTS")
    print("=" * 70)

    # Build Rust projects
    print("\n[1/2] Building Rust projects...")
    try:
        env = os.environ.copy()
        env["RUSTFLAGS"] = "-C target-cpu=native"
        subprocess.run(["cargo", "build", "--release"], check=True, env=env)
        print("  ✓ Rust build complete")
    except subprocess.CalledProcessError as e:
        print(f"  ✗ Rust build failed: {e}")
        sys.exit(1)

    # Build C++ projects
    print("\n[2/2] Building C++ projects...")

    for fmt in formats:
        if fmt not in IMPLEMENTATIONS:
            continue

        for impl in IMPLEMENTATIONS[fmt]:
            if impl["lang"] != "cpp":
                continue

            bin_path = impl["bin"]
            build_dir = os.path.dirname(bin_path)
            src_dir = os.path.dirname(build_dir)

            print(f"  Building {impl['name']}...")
            os.makedirs(build_dir, exist_ok=True)

            try:
                # Configure with CMake
                result = subprocess.run(
                    [
                        "cmake",
                        "..",
                        "-DCMAKE_BUILD_TYPE=Release",
                        "-D",
                        "CMAKE_C_COMPILER_LAUNCHER=ccache",
                        "-D",
                        "CMAKE_CXX_COMPILER_LAUNCHER=ccache",
                    ],
                    cwd=build_dir,
                    check=True,
                    capture_output=True,
                    text=True,
                )
                # Build
                result = subprocess.run(
                    ["make", "-j"],
                    cwd=build_dir,
                    check=True,
                    capture_output=True,
                    text=True,
                )

                # Verify binary was created
                if not os.path.exists(bin_path):
                    print(f"    ✗ {impl['name']} - binary not found at {bin_path}")
                    print(f"\n✗ Build failed for {impl['name']}")
                    sys.exit(1)
                else:
                    print(f"    ✓ {impl['name']}")

            except subprocess.CalledProcessError as e:
                print(f"    ✗ {impl['name']} failed")
                print(f"\n    Error output:")
                if e.stderr:
                    for line in e.stderr.strip().split("\n")[
                        :10
                    ]:  # Show first 10 lines
                        print(f"      {line}")
                if e.stdout:
                    for line in e.stdout.strip().split("\n")[:10]:
                        print(f"      {line}")
                print(f"\n✗ Build failed for {impl['name']}")
                sys.exit(1)

    print("\n✓ Build phase complete\n")


def get_dataset_files(dataset_name: str) -> List[str]:
    """Get list of files for a given dataset."""
    if dataset_name not in DATASETS:
        raise ValueError(f"Unknown dataset: {dataset_name}")

    dataset = DATASETS[dataset_name]

    # Special case: DIV2K loads from selected.txt
    if dataset_name == "div2k":
        selected_file = "data/div2k/selected.txt"
        if not os.path.exists(selected_file):
            print(f"Error: {selected_file} not found. Run setup_data.sh first.")
            sys.exit(1)

        with open(selected_file) as f:
            filenames = [line.strip() for line in f if line.strip()]

        return [f"data/div2k/DIV2K_train_HR/{name}" for name in filenames]

    files = dataset["files"]

    # Validate files exist
    missing = [f for f in files if not os.path.exists(f)]
    if missing:
        print(f"Error: Dataset '{dataset_name}' files not found:")
        for f in missing[:5]:  # Show first 5
            print(f"  - {f}")
        if len(missing) > 5:
            print(f"  ... and {len(missing) - 5} more")
        print("\nRun setup_data.sh to download datasets.")
        sys.exit(1)

    return files


def get_input_file(fmt: str, bench_type: str, quality: str) -> str:
    """Determine input file based on format and benchmark type (legacy single-file mode)."""
    if bench_type == "encode":
        # For encoding, use raw PPM
        return "data/test.ppm"
    else:
        # For decoding, use pre-encoded files with quality tier
        format_map = {
            "jpeg": "jpg",
            "png": "png",
            "webp": "webp",
            "avif": "avif",
            "jxl": "jxl",
        }
        ext = format_map.get(fmt, "jpg")

        # PNG is lossless, so no quality tier
        if fmt == "png":
            return f"data/test.{ext}"

        return f"data/test_{quality}.{ext}"


def run_benchmarks(args):
    """Execute benchmarks using hyperfine."""
    formats = args.formats.split(",") if args.formats else list(IMPLEMENTATIONS.keys())

    # Validate formats
    for fmt in formats:
        if fmt not in IMPLEMENTATIONS:
            print(f"Error: Unknown format '{fmt}'")
            print(f"Available formats: {', '.join(IMPLEMENTATIONS.keys())}")
            sys.exit(1)

    # Build projects
    build_projects(formats, args.skip_build)

    # Create results directory
    os.makedirs("results", exist_ok=True)
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    result_dir = f"results/{timestamp}"
    os.makedirs(result_dir, exist_ok=True)

    print("=" * 70)
    print("COLLECTING BENCHMARK COMMANDS")
    print("=" * 70)

    # Generate manifest
    manifest = {
        **get_system_info(),
        "compiler": get_compiler_versions(),
        "libraries": get_library_versions(),
        "allocator": "mimalloc 2.1.2",
        "benchmark_config": {
            "formats": formats,
            "type": args.type,
            "dataset": args.dataset,
            "threads": args.threads,
            "iterations": args.iterations,
            "warmup": args.warmup,
            "quality": args.quality,
            "discard_output": args.discard_output,
            "verify": args.verify,
            "preallocate": args.preallocate,
            "pin_cores": args.pin_cores,
        },
    }

    with open(f"{result_dir}/manifest.json", "w") as f:
        json.dump(manifest, f, indent=2)

    print(f"\n✓ Manifest written to {result_dir}/manifest.json")

    # Build command list
    commands = []
    command_names = []

    for fmt in formats:
        for impl in IMPLEMENTATIONS[fmt]:
            # Filter by type
            if args.type == "decode" and impl["type"] != "decode":
                continue
            if args.type == "encode" and impl["type"] != "encode":
                continue

            binary = impl["bin"]
            if not os.path.exists(binary):
                print(f"Warning: Binary not found, skipping: {binary}")
                continue

            # Get all files for the dataset
            dataset_files = get_dataset_files(args.dataset)

            for source_file in dataset_files:
                # Determine input file path
                if impl["type"] == "encode":
                    # For encoding, use the source file directly
                    # Note: Some C++ implementations might expect PPM.
                    # If source is PNG and impl needs PPM, we might need on-the-fly conversion.
                    # For now, we assume implementations can handle the source format (mostly PNG).
                    input_file = source_file
                else:
                    # For decoding, use pre-encoded files with quality tier
                    base_path = os.path.splitext(source_file)[0]
                    format_map = {
                        "jpeg": "jpg",
                        "png": "png",
                        "webp": "webp",
                        "avif": "avif",
                        "jxl": "jxl",
                    }
                    ext = format_map.get(fmt, "jpg")

                    if fmt == "png":
                        # PNG is lossless, use source file (which is usually PNG)
                        # If source is PPM (test.ppm), we use test.png
                        if source_file.endswith(".ppm"):
                            input_file = f"{base_path}.png"
                        else:
                            input_file = source_file
                    else:
                        input_file = f"{base_path}_{args.quality}.{ext}"

                if not os.path.exists(input_file):
                    # Only warn if verbose? Or just skip?
                    # For now, skip silently to avoid spam if generation failed for some
                    continue

                output_file = "/dev/null"

                # Build command
                cmd_parts = [
                    binary,
                    "--input",
                    input_file,
                    "--output",
                    output_file,
                    "--quality",
                    args.quality,
                    "--iterations",
                    str(args.iterations),
                    "--warmup",
                    str(args.warmup),
                    "--threads",
                    str(args.threads),
                ]

                if args.discard_output:
                    cmd_parts.append("--discard")

                if args.verify:
                    cmd_parts.append("--verify")

                if args.preallocate:
                    cmd_parts.append("--preallocate")

                # Wrap with /usr/bin/time if measuring memory
                if args.measure_memory:
                    cmd_parts = ["/usr/bin/time", "-v"] + cmd_parts

                # Wrap with taskset for core pinning (pin to cores 0-3 for consistency)
                if args.pin_cores:
                    cmd_parts = ["taskset", "-c", "0-3"] + cmd_parts

                commands.append(" ".join(cmd_parts))

                # Create descriptive name
                input_name = os.path.basename(input_file)
                command_names.append(
                    f"{impl['name']} ({fmt}, {impl['type']}, {input_name})"
                )

    if not commands:
        print("\nError: No benchmarks to run!")
        sys.exit(1)

    print(f"\n✓ {len(commands)} benchmark(s) ready to run\n")

    # Run hyperfine
    print("=" * 70)
    print("RUNNING BENCHMARKS")
    print("=" * 70)
    print()

    json_output = f"{result_dir}/raw.json"
    hyperfine_cmd = [
        "hyperfine",
        "--warmup",
        "3",
        "--min-runs",
        "10",
        "--export-json",
        json_output,
    ]

    # Add command names for better output
    for name in command_names:
        hyperfine_cmd.extend(["--command-name", name])

    hyperfine_cmd.extend(commands)

    try:
        subprocess.run(hyperfine_cmd, check=True)
    except FileNotFoundError:
        print("\nError: 'hyperfine' not found. Please install it:")
        print("  cargo install hyperfine")
        sys.exit(1)
    except subprocess.CalledProcessError:
        print("\nError: Benchmark execution failed")
        sys.exit(1)

    # Generate summary
    generate_summary(result_dir, json_output)

    # Measure memory if requested
    if args.measure_memory:
        measure_memory(result_dir, commands, command_names)

    print("\n" + "=" * 70)
    print("RESULTS")
    print("=" * 70)
    print(f"\nResults saved to: {result_dir}/")
    print(f"  - manifest.json  : Reproducibility metadata")
    print(f"  - raw.json       : Full hyperfine output")
    print(f"  - summary.md     : Human-readable tables")
    if args.measure_memory:
        print(f"  - memory.csv     : Peak memory usage")
    print()


def measure_memory(result_dir: str, commands: List[str], command_names: List[str]):
    """Measure peak memory usage using /usr/bin/time."""
    import re

    print("\n" + "=" * 70)
    print("MEASURING MEMORY USAGE")
    print("=" * 70)
    print()

    memory_data = []

    import platform

    for cmd, name in zip(commands, command_names):
        print(f"Measuring: {name}")

        # Remove any core pinning wrapper for clean memory measurement
        cmd_parts = cmd.split()
        system = platform.system()

        # Remove Linux 'taskset' wrapper
        if system == "Linux" and "taskset" in cmd_parts:
            try:
                idx = cmd_parts.index("taskset")
                # Find the next argument after core list (e.g., 'taskset -c 0-3 ...')
                # Accept both '-c 0-3' and '-c', '0-3'
                if cmd_parts[idx + 1] == "-c":
                    cmd_parts = cmd_parts[idx + 3 :]
                else:
                    cmd_parts = cmd_parts[idx + 2 :]
                cmd = " ".join(cmd_parts)
            except Exception:
                pass

        # Remove macOS 'cpuset' wrapper (if ever used)
        elif system == "Darwin" and "cpuset" in cmd_parts:
            try:
                idx = cmd_parts.index("cpuset")
                # cpuset -l 0-3 -- ...
                if cmd_parts[idx + 1] == "-l":
                    # Find '--' separator
                    if "--" in cmd_parts:
                        sep = cmd_parts.index("--", idx)
                        cmd_parts = cmd_parts[sep + 1 :]
                    else:
                        cmd_parts = cmd_parts[idx + 3 :]
                else:
                    cmd_parts = cmd_parts[idx + 1 :]
                cmd = " ".join(cmd_parts)
            except Exception:
                pass

        # On Windows, skip pinning (no-op)
        # (No wrapper expected)

        # Run with /usr/bin/time -v (Linux), /usr/bin/time -l (macOS), warn on Windows
        if system == "Linux":
            time_cmd = ["/usr/bin/time", "-v"] + cmd.split()
        elif system == "Darwin":
            time_cmd = ["/usr/bin/time", "-l"] + cmd.split()
        else:
            print("  Warning: Memory measurement not supported on this platform.")
            memory_data.append({"name": name, "peak_rss_mb": 0, "peak_rss_kb": 0})
            continue

        try:
            result = subprocess.run(
                time_cmd, capture_output=True, text=True, timeout=30
            )
            stderr = result.stderr
            # Linux: Parse 'Maximum resident set size (kbytes): NNNN'
            if system == "Linux":
                rss_match = re.search(
                    r"Maximum resident set size \(kbytes\): (\d+)", stderr
                )
                peak_rss_kb = int(rss_match.group(1)) if rss_match else 0
                peak_rss_mb = peak_rss_kb / 1024.0
            # macOS: Parse 'maximum resident set size' (bytes)
            elif system == "Darwin":
                rss_match = re.search(r"maximum resident set size\s+(\d+)", stderr)
                peak_rss_kb = int(rss_match.group(1)) / 1024.0 if rss_match else 0
                peak_rss_mb = peak_rss_kb / 1024.0
            else:
                peak_rss_kb = 0
                peak_rss_mb = 0

            memory_data.append(
                {"name": name, "peak_rss_mb": peak_rss_mb, "peak_rss_kb": peak_rss_kb}
            )

        except subprocess.TimeoutExpired:
            print(f"  Warning: Timeout measuring {name}")
            memory_data.append({"name": name, "peak_rss_mb": 0, "peak_rss_kb": 0})
        except Exception as e:
            print(f"  Warning: Error measuring {name}: {e}")
            memory_data.append({"name": name, "peak_rss_mb": 0, "peak_rss_kb": 0})

    # Write CSV
    csv_path = f"{result_dir}/memory.csv"
    with open(csv_path, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=["name", "peak_rss_mb", "peak_rss_kb"])
        writer.writeheader()
        writer.writerows(memory_data)

    print(f"\n✓ Memory data written to {csv_path}")


def generate_summary(result_dir: str, raw_json_path: str):
    """Generate summary.md from hyperfine results."""
    try:
        with open(raw_json_path) as f:
            data = json.load(f)
    except Exception as e:
        print(f"Warning: Could not generate summary: {e}")
        return

    import scipy.stats as stats

    summary_path = f"{result_dir}/summary.md"

    with open(summary_path, "w") as f:
        f.write("# Benchmark Results\n\n")
        f.write(f"Generated: {datetime.datetime.now().isoformat()}\n\n")

        f.write("## Summary\n\n")
        f.write(
            "| Implementation | Mean (ms) | Std Dev (ms) | 95% CI (ms) | Min (ms) | Max (ms) |\n"
        )
        f.write(
            "|---------------|-----------|--------------|-------------|----------|----------|\n"
        )

        for result in data.get("results", []):
            name = result.get("command", "unknown")
            mean = result.get("mean", 0) * 1000  # Convert to ms
            stddev = result.get("stddev", 0) * 1000
            min_time = result.get("min", 0) * 1000
            max_time = result.get("max", 0) * 1000

            # Calculate 95% confidence interval
            # Hyperfine provides times array, but we'll use mean ± 1.96*stderr
            # stderr = stddev / sqrt(n)
            times = result.get("times", [])
            n = len(times) if times else 10  # Default to 10 if not available
            stderr = stddev / (n**0.5)
            ci_margin = 1.96 * stderr  # 95% CI
            ci_lower = mean - ci_margin
            ci_upper = mean + ci_margin
            ci_str = f"{ci_lower:.2f}–{ci_upper:.2f}"

            f.write(
                f"| {name} | {mean:.2f} | {stddev:.2f} | {ci_str} | {min_time:.2f} | {max_time:.2f} |\n"
            )

        f.write("\n## Detailed Results\n\n")

        for result in data.get("results", []):
            name = result.get("command", "unknown")
            mean = result.get("mean", 0) * 1000
            median = result.get("median", 0) * 1000
            stddev = result.get("stddev", 0) * 1000
            min_time = result.get("min", 0) * 1000
            max_time = result.get("max", 0) * 1000

            # Calculate 95% CI
            times = result.get("times", [])
            n = len(times) if times else 10
            stderr = stddev / (n**0.5)
            ci_margin = 1.96 * stderr
            ci_lower = mean - ci_margin
            ci_upper = mean + ci_margin

            f.write(f"### {name}\n\n")
            f.write(f"- **Mean**: {mean:.2f} ms\n")
            f.write(f"- **Median**: {median:.2f} ms\n")
            f.write(f"- **Std Dev**: {stddev:.2f} ms\n")
            f.write(f"- **95% CI**: {ci_lower:.2f} ms – {ci_upper:.2f} ms\n")
            f.write(f"- **Min**: {min_time:.2f} ms\n")
            f.write(f"- **Max**: {max_time:.2f} ms\n")
            f.write("\n")

    print(f"\n✓ Summary written to {summary_path}")


def main():
    parser = argparse.ArgumentParser(
        description="Run image codec benchmarks",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  ./bench                           # Run all benchmarks with defaults (test dataset)
  ./bench --dataset kodak           # Benchmark on KODAK dataset (24 images)
  ./bench --dataset div2k           # Benchmark on DIV2K selected (20 high-res images)
  ./bench --dataset pathological    # Benchmark on synthetic stress tests
  ./bench --formats jpeg,avif       # Only test JPEG and AVIF
  ./bench --type decode             # Only decode benchmarks
  ./bench --threads 0               # Use all available cores
  ./bench --discard-output          # Pure compute (no I/O)
  ./bench --verify                  # Include correctness verification
  ./bench --measure-memory          # Track peak memory usage
        """,
    )

    parser.add_argument(
        "--formats",
        help="Comma-separated list of formats to benchmark (jpeg,png,webp,avif,jxl)",
    )
    parser.add_argument(
        "--dataset",
        choices=["test", "kodak", "div2k", "pathological"],
        default="test",
        help="Dataset to benchmark (default: test)",
    )
    parser.add_argument(
        "--type",
        choices=["encode", "decode", "both"],
        default="decode",
        help="Benchmark type (default: decode)",
    )
    parser.add_argument(
        "--threads",
        type=int,
        default=1,
        help="Number of threads (0 = all cores, default: 1)",
    )
    parser.add_argument(
        "--iterations",
        type=int,
        default=10,
        help="Number of iterations per benchmark (default: 10)",
    )
    parser.add_argument(
        "--warmup", type=int, default=2, help="Number of warmup iterations (default: 2)"
    )
    parser.add_argument(
        "--quality",
        choices=["web-low", "web-high", "archival"],
        default="web-low",
        help="Quality tier to test (default: web-low)",
    )
    parser.add_argument(
        "--discard-output",
        action="store_true",
        help="Discard output (compute-only, no I/O)",
    )
    parser.add_argument(
        "--verify", action="store_true", help="Enable correctness verification"
    )
    parser.add_argument(
        "--preallocate",
        action="store_true",
        help="Preallocate buffers (isolate from allocator variance)",
    )
    parser.add_argument(
        "--measure-memory",
        action="store_true",
        help="Measure peak memory usage (requires /usr/bin/time)",
    )
    parser.add_argument(
        "--skip-build", action="store_true", help="Skip compilation step"
    )
    parser.add_argument(
        "--pin-cores",
        action="store_true",
        help="Pin benchmarks to specific CPU cores using taskset (Linux only)",
    )

    args = parser.parse_args()

    try:
        run_benchmarks(args)
    except KeyboardInterrupt:
        print("\n\nBenchmark interrupted by user")
        sys.exit(1)


if __name__ == "__main__":
    main()
