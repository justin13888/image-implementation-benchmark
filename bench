class Dataset:
    def __init__(
        self, description: str, files: Union[list[str], Callable[[], list[str]]]
    ):
        self.description = description
        self._files = files

    @property
    def files(self) -> list[str]:
        if callable(self._files):
            return self._files()
        return self._files


