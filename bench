# TODO: Verify it works on macOS and Windows vv
def get_system_info() -> Dict[str, Any]:
    """Collect system information for reproducibility manifest."""
    info = {
        "timestamp": datetime.datetime.now().isoformat() + "Z",
        "os": f"{platform.system()} {platform.release()}",
        "kernel": platform.version(),
        "cpu": "unknown",
        "cores": os.cpu_count() or 0,
    }

    # Try to get CPU info
    try:
        if platform.system() == "Darwin":
            cpu = (
                subprocess.check_output(["sysctl", "-n", "machdep.cpu.brand_string"])
                .decode()
                .strip()
            )
            info["cpu"] = cpu
        elif platform.system() == "Linux":
            with open("/proc/cpuinfo") as f:
                for line in f:
                    if "model name" in line:
                        info["cpu"] = line.split(":")[1].strip()
                        break
    except Exception:
        pass

    return info


def get_compiler_versions() -> Dict[str, str]:
    """Get versions of all compilers used."""
    versions = {}

    try:
        versions["rustc"] = (
            subprocess.check_output(["rustc", "--version"]).decode().strip()
        )
    except Exception:
        versions["rustc"] = "not found"

    try:
        clang_out = subprocess.check_output(
            ["clang", "--version"], stderr=subprocess.STDOUT
        ).decode()
        versions["clang"] = clang_out.split("\n")[0].strip()
    except Exception:
        versions["clang"] = "not found"

    try:
        versions["cmake"] = (
            subprocess.check_output(["cmake", "--version"])
            .decode()
            .split("\n")[0]
            .strip()
        )
    except Exception:
        versions["cmake"] = "not found"

    return versions


def get_library_versions() -> Dict[str, str]:
    """Attempt to determine versions of image libraries."""
    libraries = {}

    libs_to_check = [
        "libjpeg-turbo",
        "libpng",
        "libwebp",
        "libavif",
        "dav1d",
        "libjxl",
    ]

    for lib in libs_to_check:
        try:
            result = (
                subprocess.check_output(
                    ["pkg-config", "--modversion", lib], stderr=subprocess.DEVNULL
                )
                .decode()
                .strip()
            )
            libraries[lib] = result
        except Exception:
            libraries[lib] = "unknown"

    libraries["mozjpeg"] = "unknown"
    libraries["mimalloc"] = "2.1.2"  # Would need to be detected dynamically
    libraries["hyperfine"] = "unknown"

    try:
        hf_version = (
            subprocess.check_output(["hyperfine", "--version"]).decode().strip()
        )
        libraries["hyperfine"] = (
            hf_version.split()[1] if len(hf_version.split()) > 1 else hf_version
        )
    except Exception:
        pass

    return libraries


def build_projects(formats: list[ImageFormat], skip_build: bool):
    """Build Rust and C++ projects."""
    if skip_build:
        print("Skipping build step (--skip-build)")
        return

    print("=" * 70)
    print("BUILDING PROJECTS")
    print("=" * 70)

    # Build Rust projects
    print("\n[1/2] Building Rust projects...")
    try:
        env = os.environ.copy()
        env["RUSTFLAGS"] = "-C target-cpu=native"
        subprocess.run(["cargo", "build", "--release"], check=True, env=env)
        print("  ✓ Rust build complete")
    except subprocess.CalledProcessError as e:
        print(f"  ✗ Rust build failed: {e}")
        sys.exit(1)

    # Build C++ projects
    print("\n[2/2] Building C++ projects...")

    for fmt in formats:
        if fmt not in IMPLEMENTATIONS:
            continue

        for impl in chain(
            NULL_IMPLEMENTATIONS,
            (impl for impl in IMPLEMENTATIONS if impl.format == fmt),
        ):
            if impl.lang != "cpp":
                continue

            bin_path = impl.bin
            build_dir = os.path.dirname(bin_path)
            # src_dir = os.path.dirname(build_dir)

            print(f"  Building {impl.name}...")
            os.makedirs(build_dir, exist_ok=True)

            try:
                # Configure with CMake
                subprocess.run(
                    [
                        "cmake",
                        "..",
                        "-DCMAKE_BUILD_TYPE=Release",
                        "-D",
                        "CMAKE_C_COMPILER_LAUNCHER=ccache",
                        "-D",
                        "CMAKE_CXX_COMPILER_LAUNCHER=ccache",
                    ],
                    cwd=build_dir,
                    check=True,
                    capture_output=True,
                    text=True,
                )
                # Build
                subprocess.run(
                    ["make", "-j"],
                    cwd=build_dir,
                    check=True,
                    capture_output=True,
                    text=True,
                )

                # Verify binary was created
                if not os.path.exists(bin_path):
                    print(f"    ✗ {impl.name} - binary not found at {bin_path}")
                    print(f"\n✗ Build failed for {impl.name}")
                    sys.exit(1)
                else:
                    print(f"    ✓ {impl.name}")

            except subprocess.CalledProcessError as e:
                print(f"    ✗ {impl.name} failed")
                print("\n    Error output:")
                if e.stderr:
                    for line in e.stderr.strip().split("\n")[
                        :10
                    ]:  # Show first 10 lines
                        print(f"      {line}")
                if e.stdout:
                    for line in e.stdout.strip().split("\n")[:10]:
                        print(f"      {line}")
                print(f"\n✗ Build failed for {impl.name}")
                sys.exit(1)

    print("\n✓ Build phase complete\n")


def get_dataset_files(dataset_name: DatasetId) -> list[str]:
    """
    Get list of files for a given dataset.

    Guarantees that all files exist, otherwise exits with error message.
    """
    # TODO: Cache the result of this
    if dataset_name not in DATASETS:
        raise ValueError(f"Unknown dataset: {dataset_name}")

    dataset = DATASETS[dataset_name]
    files = dataset.files

    # Validate files exist
    missing = [f for f in files if not os.path.exists(f)]
    if missing:
        print(f"Error: Dataset '{dataset_name}' files not found:")
        for f in missing[:5]:  # Show first 5
            print(f"  - {f}")
        if len(missing) > 5:
            print(f"  ... and {len(missing) - 5} more")
        print("\nRun setup_data.sh to download datasets.")
        sys.exit(1)

    return files


def get_input_files(
    dataset_name: DatasetId,
    format: InputImageFormat,
    quality: QualityTier,
) -> Sequence[str]:
    """
    Get list of input files for a given dataset, benchmark type."

    Pre-generates input files for benchmark type if necessary
    """

    if (dataset_name, format) in INPUT_FILES_CACHE:
        return INPUT_FILES_CACHE[(dataset_name, format)]

    # Get all files for the dataset
    dataset_files = get_dataset_files(args.dataset)

    input_files = []
    target_ext = FORMAT_EXT_MAP[format]

    for f in dataset_files:
        if f.lower().endswith(f".{target_ext}"):
            # Dataset file already in required format
            input_files.append(f)
        else:
            base_path = os.path.splitext(f)[0]
            if is_format_lossless(format):
                target_file = f"{base_path}.{target_ext}"
            else:
                target_file = f"{base_path}_{quality.value}.{target_ext}"
            if os.path.exists(target_file):
                input_files.append(target_file)
            else:
                # Need to convert dataset file into required format
                raise NotImplementedError(
                    f"Dataset file {f} does not match target format {format}. "
                )
    # Verify all input files exist
    missing = [f for f in input_files if not os.path.exists(f)]
    if missing:
        raise RuntimeError(
            f"Some input files not found {len(missing)} for '{dataset_name}': {','.join(missing[:5])}"
        )

    INPUT_FILES_CACHE[(dataset_name, format)] = input_files
    return input_files


def build_bench_cmd(
    impl: Implementation,
    fmt: ImageFormat,
    input_path: str,
    output_path: str,
    args: BenchmarkArgs,
) -> tuple[str, str]:
    """Generate [name, command] for a given implementation and parameters."""
    binary = impl.bin

    # Build command
    cmd_parts = [
        binary,
        "--input",
        input_path,
        "--output",
        output_path,
        "--quality",
        args.quality,
        "--iterations",
        str(args.iterations),
        "--warmup",
        str(args.warmup),
        "--threads",
        str(args.threads),
    ]

    if args.discard_output:
        cmd_parts.append("--discard")

    if args.verify:
        cmd_parts.append("--verify")

    if args.preallocate:
        cmd_parts.append("--preallocate")

    # Wrap with /usr/bin/time if measuring memory
    if args.measure_memory:
        cmd_parts = ["/usr/bin/time", "-v"] + cmd_parts

    # Wrap with taskset for core pinning (pin to cores 0-3 for consistency)
    if args.pin_cores:
        cmd_parts = ["taskset", "-c", "0-3"] + cmd_parts

    command = " ".join(cmd_parts)
    name = (
        f"{impl.name} ({fmt.value}, {impl.type.value}, {os.path.basename(output_path)})"
    )

    return (name, command)


# Build list is list[[name, cmd]]
BenchList = list[tuple[str, str]]


def build_bench_list(
    type: BenchmarkType,
    format: ImageFormat,
) -> BenchList:
    """Construct list of benchmark commands to run."""
    # Construct list of implementations to run
    # For each format, we get the null implementation + implementations that support that format, together filtered by type
    implementations: Iterator[Implementation] = chain(
        (impl for impl in NULL_IMPLEMENTATIONS if impl.type == type),
        (
            impl
            for impl in IMPLEMENTATIONS
            if impl.format == format and impl.type == type
        ),
    )

    # Construct bench list
    benches: BenchList = []
    for impl in implementations:
        # Verify binary exists
        if not os.path.exists(impl.bin):
            print(f"Warning: Binary not found, skipping: {impl.bin}")
            continue

        # Determine correct input format
        match impl.type:
            case BenchmarkType.DECODE:
                input_format = format
            case BenchmarkType.ENCODE:
                input_format = PPMImageFormat.PPM
            case _:
                raise ValueError(f"Unknown implementation type: {impl.type}")

        for input_file in get_input_files(args.dataset, input_format, args.quality):
            # input_path = "{input}"  # Note: This isn't an f-string
            input_path = input_file
            output_path = "/dev/null"
            bench = build_bench_cmd(
                impl, format, input_path, output_path, args
            )  # TODO: pass appropriate
            benches.append(bench)

    return benches


def run_benchmarks(args: BenchmarkArgs):
    """Execute benchmarks using hyperfine."""
    formats = args.formats or list(ImageFormat)

    # Build projects
    build_projects(formats, args.skip_build)

    # Create results directory
    os.makedirs("results", exist_ok=True)
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    result_dir = f"results/{timestamp}"
    os.makedirs(result_dir, exist_ok=True)

    print("=" * 70)
    print("COLLECTING BENCHMARK COMMANDS")
    print("=" * 70)

    # Generate manifest
    manifest = {
        **get_system_info(),
        "compiler": get_compiler_versions(),
        "libraries": get_library_versions(),
        "allocator": "mimalloc 2.1.2",
        "benchmark_config": {
            "formats": formats,
            "mode": args.mode,
            "dataset": args.dataset,
            "threads": args.threads,
            "iterations": args.iterations,
            "warmup": args.warmup,
            "quality": args.quality,
            "discard_output": args.discard_output,
            "verify": args.verify,
            "preallocate": args.preallocate,
            "pin_cores": args.pin_cores,
        },
    }

    with open(f"{result_dir}/manifest.json", "w") as f:
        json.dump(manifest, f, indent=2)

    print(f"\n✓ Manifest written to {result_dir}/manifest.json")

    benches: BenchList = []
    for format in formats:
        match args.mode:
            case BenchmarkMode.ENCODE:
                benches += build_bench_list(BenchmarkType.ENCODE, format)
            case BenchmarkMode.DECODE:
                benches += build_bench_list(BenchmarkType.DECODE, format)
            case BenchmarkMode.BOTH:
                benches += build_bench_list(BenchmarkType.ENCODE, format)
                benches += build_bench_list(BenchmarkType.DECODE, format)
            case _:
                raise ValueError(f"Unknown benchmark type: {args.mode}")
    # TODO: Split into encode and decode benches later

    if not benches:
        print("\nError: No benchmarks to run!")
        sys.exit(1)

    print(f"\n✓ {len(benches)} benchmark(s) ready to run\n")

    # Run hyperfine
    print("=" * 70)
    print("RUNNING BENCHMARKS")
    print("=" * 70)
    print()

    json_output = f"{result_dir}/raw.json"
    if not args.quick:
        hyperfine_cmd = [
            "hyperfine",
            "--warmup",
            "3",
            "--min-runs",
            "10",
            "--export-json",
            json_output,
        ]
    else:
        hyperfine_cmd = [
            "hyperfine",
            "--warmup",
            "0",
            "--min-runs",
            "1",
            "--max-runs",
            "1",
            "--export-json",
            json_output,
        ]

    # Add command names for better output
    for name, _ in benches:
        hyperfine_cmd.extend(["--command-name", name])

    hyperfine_cmd.extend([cmd for _, cmd in benches])

    # --show-output if debug
    if args.debug:
        hyperfine_cmd.append("--show-output")

    try:
        subprocess.run(hyperfine_cmd, check=True)
    except FileNotFoundError:
        print("\nError: 'hyperfine' not found")
        sys.exit(1)
    except subprocess.CalledProcessError:
        print("\nError: Benchmark execution failed")
        print(f"Test command: {' '.join(hyperfine_cmd)}")
        sys.exit(1)

    # Generate summary
    generate_summary(result_dir, json_output)

    # Measure memory if requested
    if args.measure_memory:
        pass  # TODO: This function is buggy at best.
        # measure_memory(result_dir, commands, command_names)

    print("\n" + "=" * 70)
    print("RESULTS")
    print("=" * 70)
    print(f"\nResults saved to: {result_dir}/")
    print("  - manifest.json  : Reproducibility metadata")
    print("  - raw.json       : Full hyperfine output")
