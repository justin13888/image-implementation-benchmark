def create_plots_from_parsed_results(
    parsed: Dict[str, Dict[str, list[Dict[str, Any]]]],
) -> list[Tuple[str, "Figure"]]:
    """Create matplotlib figures from parsed results.

    Returns a list of tuples (filename, Figure).
    The caller is responsible for saving and closing the figures.
    """

    # Import locally to avoid heavy imports at module import-time
    import matplotlib.pyplot as plt
    import numpy as np

    plots: list[Tuple[str, "Figure"]] = []

    for bench_type, codecs in parsed.items():
        if not codecs:
            continue

        sorted_codecs = sorted(codecs.keys())

        for fmt in sorted_codecs:
            results = codecs[fmt]
            # Sort by mean time
            results.sort(key=lambda x: x["mean"])

            names = [r["name"] for r in results]
            means = [r["mean"] for r in results]
            stddevs = [r["stddev"] for r in results]

            y_pos = np.arange(len(names))

            fig, ax = plt.subplots(
                figsize=(10, 0.5 * max(4, len(names))), constrained_layout=True
            )
            fig.suptitle(
                f"{bench_type.capitalize()} - {fmt.upper()} Benchmarks", fontsize=14
            )
            ax.barh(y_pos, means, xerr=stddevs, align="center", alpha=0.8, capsize=5)
            ax.set_yticks(y_pos)
            ax.set_yticklabels(names)
            ax.invert_yaxis()  # labels read top-to-bottom
            ax.set_xlabel("Time (ms)")
            ax.set_title(f"{fmt.upper()}")

            # Add value labels
            for j, v in enumerate(means):
                ax.text(v, j, f" {v:.2f} ms", va="center")

            filename = f"{bench_type}_{fmt}_results.png"
            plots.append((filename, fig))

    return plots


def generate_summary(result_dir: str, raw_json_path: str):
    """Generate summary.md from hyperfine results."""
    try:
        with open(raw_json_path) as f:
            data = json.load(f)
    except Exception as e:
        print(f"Warning: Could not generate summary: {e}")
        return

    # Imports used for other helper code are handled in the helper

    # Parse results
    parsed_results = {"encode": {}, "decode": {}}

    for result in data.get("results", []):
        name = result.get("command", "unknown")
        # Format: "impl_name (fmt, type, input)"
        try:
            # Extract info from name
            if "(" in name and ")" in name:
                base_name = name.split(" (")[0]
                meta = name.split(" (")[1].rstrip(")").split(", ")
                if len(meta) >= 2:
                    fmt = meta[0]
                    bench_type = meta[1]

                    if bench_type in parsed_results:
                        if fmt not in parsed_results[bench_type]:
                            parsed_results[bench_type][fmt] = []

                        parsed_results[bench_type][fmt].append(
                            {
                                "name": base_name,
                                "mean": (result.get("mean") or 0) * 1000,  # ms
                                "stddev": (result.get("stddev") or 0) * 1000,  # ms
                            }
                        )
        except Exception:
            continue

    # Use the module-level plotting helper to create figures

    # TODO: Sort "Detailed Results" by format and then benchmark type
    # Generate plots using the helper and export them individually
    plot_files: list[Tuple[str, str]] = []  # (bench_type, filename)
    plots = create_plots_from_parsed_results(parsed_results)

    import matplotlib.pyplot as plt

    for filename, fig in plots:
        filepath = os.path.join(result_dir, filename)
        fig.savefig(filepath)
        plt.close(fig)
        # bench_type is the prefix before the first underscore
        bench_type = filename.split("_")[0] if "_" in filename else "summary"
        plot_files.append((bench_type, filename))

    summary_path = f"{result_dir}/summary.md"

    with open(summary_path, "w") as f:
        f.write("# Benchmark Results\n\n")
        f.write(f"Generated: {datetime.datetime.now().isoformat()}\n\n")

        f.write("## Summary\n\n")
        f.write(
            "| Implementation | Mean (ms) | Std Dev (ms) | 95% CI (ms) | Min (ms) | Max (ms) |\n"
        )
        f.write(
            "|---------------|-----------|--------------|-------------|----------|----------|\n"
        )

        for result in data.get("results", []):
            name = result.get("command", "unknown")
            mean = (result.get("mean") or 0) * 1000  # Convert to ms
            stddev = (result.get("stddev") or 0) * 1000
            min_time = (result.get("min") or 0) * 1000
            max_time = (result.get("max") or 0) * 1000

            # Calculate 95% confidence interval
            times = result.get("times", [])
            n = len(times) if times else 10
            stderr = stddev / (n**0.5)
            ci_margin = 1.96 * stderr
            ci_lower = mean - ci_margin
            ci_upper = mean + ci_margin
            ci_str = f"{ci_lower:.2f}–{ci_upper:.2f}"

            f.write(
                f"| {name} | {mean:.2f} | {stddev:.2f} | {ci_str} | {min_time:.2f} | {max_time:.2f} |\n"
            )

        f.write("\n## Detailed Results\n\n")

        if plot_files:
            for bench_type, filename in plot_files:
                f.write(f"### {bench_type.capitalize()}\n\n")
                f.write(f"![{bench_type} results]({filename})\n\n")
        else:
            f.write("No plots generated.\n")

    print(f"\n✓ Summary written to {summary_path}")


